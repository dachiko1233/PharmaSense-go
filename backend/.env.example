# Database (Docker local)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pharmasense?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRY_HOURS=24

# Server
PORT=3001
ENV=development
APP_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Resend (email) — leave empty or use mock_ prefix for local dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@pharmasense.cy

# Twilio (SMS) — leave empty or use mock_ prefix for local dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe — leave empty for local dev (mock checkout URLs will be returned)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CHAIN=

# Cron (set to true when running multiple instances to avoid duplicate sends)
DISABLE_CRON=false
